{
  "name": "@career-ops/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scan": {
      "types": "./dist/scan.d.ts",
      "default": "./dist/scan.js"
    },
    "./prompts": {
      "types": "./dist/prompts.d.ts",
      "default": "./dist/prompts.js"
    },
    "./pdf-normalize": {
      "types": "./dist/pdf-normalize.d.ts",
      "default": "./dist/pdf-normalize.js"
    },
    "./profile-schema": {
      "types": "./dist/profile-schema.d.ts",
      "default": "./dist/profile-schema.js"
    },
    "./states": {
      "types": "./dist/states.d.ts",
      "default": "./dist/states.js"
    },
    "./liveness": {
      "types": "./dist/liveness.d.ts",
      "default": "./dist/liveness.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
