# --- Database (Supabase Postgres or any Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/careerops?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/careerops?schema=public

# --- Auth.js v5 ---
# openssl rand -base64 32
AUTH_SECRET=replace-me
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Supabase Storage (PDFs only; auth no longer used) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cv-pdfs

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI providers ---
# Format: "<provider>:<model>" — e.g., "anthropic:claude-sonnet-4-6", "openai:gpt-4o"
AI_MODEL=anthropic:claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Inngest ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
